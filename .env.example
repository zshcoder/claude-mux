# 代理认证 Token（Claude Code 的 ANTHROPIC_AUTH_TOKEN 必须与此一致）
AUTH_TOKEN="your-auth-token-here"

# 服务器配置
SERVER_HOST="0.0.0.0"
SERVER_PORT=12346

# CORS 允许的来源（逗号分隔，* 表示允许所有）
# 生产环境建议配置具体域名，如：https://your-app.example.com
CORS_ORIGINS="*"

# 日志配置（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL="INFO"
# 日志格式（console / json，开发推荐 console，生产推荐 json）
LOG_FORMAT="console"
# 上游等待警告延迟（秒），超过此时间未响应则输出警告日志
UPSTREAM_WAIT_WARNING_DELAY=5.0
# 上游等待警告重复间隔（秒），每隔此时间输出一次警告日志
UPSTREAM_WAIT_WARNING_REPEAT_INTERVAL=5.0

# 路由组名称（逗号分隔，每组需配置 {NAME}_PATTERN / {NAME}_UPSTREAM / {NAME}_AUTH_TOKEN）
ROUTE_NAMES="OPUS,SONNET,HAIKU"

# Opus 模型
OPUS_PATTERN="claude-opus-*"
OPUS_UPSTREAM="https://your-opus-upstream.example.com"
OPUS_AUTH_TOKEN="your-opus-auth-token"

# Sonnet 模型
SONNET_PATTERN="glm-*"
SONNET_UPSTREAM="https://your-sonnet-upstream.example.com"
SONNET_AUTH_TOKEN="your-sonnet-auth-token"

# Haiku 模型
HAIKU_PATTERN="MiniMax-*"
HAIKU_UPSTREAM="https://your-haiku-upstream.example.com"
HAIKU_AUTH_TOKEN="your-haiku-auth-token"
